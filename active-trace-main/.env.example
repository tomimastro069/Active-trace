# Example environment variables for active-trace project
# Copy this to .env (or reference directly) and fill in real secrets.

# FastAPI settings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/active_trace_db
SECRET_KEY=change_me_to_a_secure_key_minimum_32_chars!
ENCRYPTION_KEY=change_me_32_char_encryption_key
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Postgres defaults (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=active_trace_db
