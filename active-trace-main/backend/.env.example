# Activia Trace Backend Environment Example

# PostgreSQL connection string (use asyncpg)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/activia_trace
# Test database (used for test suite)
DATABASE_URL_TEST=postgresql+asyncpg://user:password@localhost:5432/activia_trace_test

# JWT signing secret (minimum 32 chars, not actual secret)
SECRET_KEY=changeme-in-dev-use32chars-or-more________________

# AES256 encryption key (exactly 32 chars, not secret)
ENCRYPTION_KEY=changeme-this-key-32-characters-long!

# Access token expiration in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Replace the above values for local/dev only. NEVER commit secrets.
